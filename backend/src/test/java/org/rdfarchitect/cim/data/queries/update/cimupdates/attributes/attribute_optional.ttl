PREFIX cim:    <http://iec.ch/TC57/2013/CIM-schema-cim16#>
PREFIX cims:   <http://iec.ch/TC57/1999/rdf-schema-extensions-19990926#>
PREFIX entsoe: <http://entsoe.eu/CIM/SchemaExtension/3/1#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX ex:     <http://example.com#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>

ex:class.existing_attribute
    <http://example.org#uuid> "43836908-c7f7-4749-bb8b-3ac9250de655" ;
    rdf:type            rdf:Property ;
    rdfs:label          "existing_attribute"@en ;
    rdfs:domain         ex:class ;
    rdfs:range          ex:class ;
    cims:stereotype     <http://iec.ch/TC57/NonStandard/UML#attribute> ;
    cims:multiplicity   cims:M:1..1 ;
    rdfs:comment        "This is a test"^^rdf:XMLLiteral ;
    cims:isFixed        "isFixed" ;
    cims:isDefault      "isDefault" .
