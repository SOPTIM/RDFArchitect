PREFIX cim:    <http://iec.ch/TC57/2013/CIM-schema-cim16#>
PREFIX cims:   <http://iec.ch/TC57/1999/rdf-schema-extensions-19990926#>
PREFIX entsoe: <http://entsoe.eu/CIM/SchemaExtension/3/1#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>

cim:SuperClass
    rdf:type               rdfs:Class ;
    rdfs:comment           "superClassComment"^^rdf:XMLLiteral ;
    rdfs:label             "SuperClass"@en ;
    cims:belongsToCategory cim:Package_Infrastruktur .

cim:SuperClass.attribute
    rdf:type          rdf:Property ;
    rdfs:domain       cim:SuperClass ;
    rdfs:label        "attribute"@en ;
    cims:dataType     xsd:integer ;
    cims:multiplicity cims:M:1..1 ;
    cims:stereotype   <http://iec.ch/TC57/NonStandard/UML#attribute> .

cim:ChildClass
    rdf:type               rdfs:Class ;
    rdfs:label             "ChildClass"@en ;
    rdfs:subClassOf        cim:SuperClass ;
    cims:belongsToCategory cim:Package_Infrastruktur ;
    cims:stereotype        <http://iec.ch/TC57/NonStandard/UML#concrete> .

cim:ChildClass.attribute1
    rdf:type          rdf:Property ;
    rdfs:domain       cim:ChildClass ;
    rdfs:label        "attribute1"@en ;
    cims:dataType     xsd:string ;
    cims:multiplicity cims:M:1..1 ;
    cims:stereotype   <http://iec.ch/TC57/NonStandard/UML#attribute> .

cim:ChildClass.attribute2
    rdf:type          rdf:Property ;
    rdfs:domain       cim:ChildClass ;
    rdfs:label        "attribute2"@en ;
    cims:dataType     xsd:integer ;
    cims:multiplicity cims:M:1..1 ;
    cims:stereotype   <http://iec.ch/TC57/NonStandard/UML#attribute> .

cim:ChildClass.AssociatedClass
    rdf:type             rdf:Property ;
    rdfs:domain          cim:ChildClass ;
    rdfs:label           "AssociatedClass"@en ;
    rdfs:range           cim:AssociatedClass ;
    cims:AssociationUsed "Yes" ;
    cims:inverseRoleName cim:AssociatedClass.ChildClass ;
    cims:multiplicity    cims:M:1 .

cim:AssociatedClass.ChildClass
    rdf:type             rdf:Property ;
    rdfs:domain          cim:AssociatedClass ;
    rdfs:label           "ChildClass"@en ;
    rdfs:range           cim:ChildClass ;
    cims:AssociationUsed "Yes" ;
    cims:inverseRoleName cim:ChildClass.AssociatedClass ;
    cims:multiplicity    cims:M:0..n .

cim:AssociatedClass
    rdf:type        rdfs:Class ;
    rdfs:comment    "associatedClassComment"^^rdf:XMLLiteral ;
    rdfs:label      "AssociatedClass"@en ;
    cims:stereotype <http://iec.ch/TC57/NonStandard/UML#concrete> .

cim:EnumClass
    rdf:type               rdfs:Class ;
    rdfs:comment           "enumClassComment"^^rdf:XMLLiteral ;
    rdfs:label             "EnumClass"@en ;
    cims:belongsToCategory cim:Package_Infrastruktur ;
    cims:stereotype        <http://iec.ch/TC57/NonStandard/UML#enumeration> .

cim:EnumClass.ENUMENTRY1
    rdf:type   cim:EnumClass ;
    rdfs:label "ENUMENTRY1"@en .

cim:EnumClass.ENUMENTRY2
    rdf:type   cim:EnumClass ;
    rdfs:label "ENUMENTRY2"@en .

cim:Package_Infrastruktur
    rdf:type   cims:ClassCategory ;
    rdfs:label "Infrastruktur"@en .
